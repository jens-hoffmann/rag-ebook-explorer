# =============================================================================
# Ebook RAG Explorer - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values

# ------------------------------------------------------------------------------
# Database Configuration (PostgreSQL + pgvector)
# ------------------------------------------------------------------------------
# Full database URL (asyncpg format)
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb

# Individual connection parameters (used to build DATABASE_URL if not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb

# ------------------------------------------------------------------------------
# Embedding Model (sentence-transformers compatible)
# Dimension: 384 for all-MiniLM-L6-v2, 768 for all-mpnet-base-v2
# ------------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ------------------------------------------------------------------------------
# Reranking Model (CrossEncoder compatible)
# ------------------------------------------------------------------------------
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ------------------------------------------------------------------------------
# LLM Configuration for Answer Generation
# ------------------------------------------------------------------------------
# Provider: openai | lmstudio | azure
LLM_PROVIDER=

# Model name (depends on provider)
# - openai: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# - lmstudio: any model loaded in LM Studio
# - azure: your deployment name
LLM_MODEL=

# Base URL (optional)
# - openai: leave blank for default
# - lmstudio: http://localhost:1234/v1
# - azure: https://your-resource.openai.azure.com/
LLM_BASE_URL=

# API Key (required for OpenAI and Azure)
LLM_API_KEY=

# ------------------------------------------------------------------------------
# Hybrid Search Configuration
# ------------------------------------------------------------------------------
# Vector search results (semantic similarity)
RETRIEVAL_TOP_K=20

# Full-text search results (keyword matching)
TEXT_SEARCH_TOP_K=20

# Combined results to consider before reranking
HYBRID_TOP_K=40

# RRF fusion parameter (higher = more weight to top-ranked items)
RRF_K=60

# Final results after reranking
RERANK_TOP_N=5

# ------------------------------------------------------------------------------
# Text Chunking Configuration
# ------------------------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ------------------------------------------------------------------------------
# API Server Configuration
# ------------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ------------------------------------------------------------------------------
# Model Cache Directory (for containerized deployments)
# ------------------------------------------------------------------------------
MODEL_CACHE_DIR=/app/models
